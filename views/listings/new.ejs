<h1>Create a New Listing</h1>
<form method="POST" action="/listings" novalidate class="needs-validation">
  <label>Title</label>
  <input type="text" name="listing[title]" required minlength="3"><br>
  <div class="error-msg">Please enter a title (at least 3 characters).</div>

  <label>Description</label>
  <input type="text" name="listing[description]" required><br>
  <div class="error-msg">Please enter a description.</div>

  <label>Price</label>
  <input type="number" name="listing[price]" required min="0"><br>
  <div class="error-msg">Please enter a valid price (0 or more).</div>

  <label>Location</label>
  <input type="text" name="listing[location]" required><br>
  <div class="error-msg">Please enter a location.</div>

  <label>Country</label>
  <input type="text" name="listing[country]" required><br>
  <div class="error-msg">Please enter a country.</div>

  <button type="submit">Create Listing</button>
</form>